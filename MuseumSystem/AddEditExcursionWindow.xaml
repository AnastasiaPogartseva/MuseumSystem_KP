<Window x:Class="MuseumSystem.Pages.AddEditExcursionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Добавление/Редактирование экскурсии" 
        Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleText" Grid.Row="0" Text="Добавление новой экскурсии" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

        <!-- Название экскурсии/выставки -->
        <TextBlock Grid.Row="1" Text="Название экскурсии" FontWeight="SemiBold" Margin="0,5"/>
        <ComboBox x:Name="cmbExhibition" Grid.Row="2" Height="35" Margin="0,0,0,10" 
                  DisplayMemberPath="Name" SelectedValuePath="ExhibitionID"
                  IsEditable="True"/>

        <!-- Дата проведения -->
        <TextBlock Grid.Row="3" Text="Дата проведения" FontWeight="SemiBold" Margin="0,5"/>
        <DatePicker x:Name="dpExcursionDate" Grid.Row="4" Height="35" Margin="0,0,0,10" 
                    SelectedDate="{Binding Date}" DisplayDateStart="{x:Static sys:DateTime.Today}"/>

        <!-- Время начала и окончания -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Время начала" FontWeight="SemiBold" Margin="0,5"/>
                <TextBox x:Name="txtStartTime" Height="35" Padding="5" Text="10:00" 
                         LostFocus="txtTime_LostFocus" PreviewTextInput="TimeValidationTextBox"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Время окончания" FontWeight="SemiBold" Margin="0,5"/>
                <TextBox x:Name="txtEndTime" Height="35" Padding="5" Text="11:30" 
                         LostFocus="txtTime_LostFocus" PreviewTextInput="TimeValidationTextBox"/>
            </StackPanel>
        </Grid>

        <!-- Гид -->
        <TextBlock Grid.Row="6" Text="Гид" FontWeight="SemiBold" Margin="0,5"/>
        <ComboBox x:Name="cmbGuide" Grid.Row="7" Height="35" Margin="0,0,0,10" 
                  DisplayMemberPath="FullName" SelectedValuePath="EmployeeID"/>

        <!-- Максимальное количество посетителей -->
        <TextBlock Grid.Row="8" Text="Максимальное количество посетителей" FontWeight="SemiBold" Margin="0,5"/>
        <TextBox x:Name="txtMaxVisitors" Grid.Row="9" Height="35" Margin="0,0,0,10" Padding="5" Text="20" 
                 PreviewTextInput="NumberValidationTextBox"/>

        <!-- Место сбора -->
        <TextBlock Grid.Row="10" Text="Место сбора" FontWeight="SemiBold" Margin="0,5"/>
        <TextBox x:Name="txtMeetingPoint" Grid.Row="11" Height="35" Margin="0,0,0,10" Padding="5" Text="Вестибюль музея"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35" Background="#4CAF50" 
                    Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" Background="#f44336" 
                    Foreground="White" BorderThickness="0" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>