<Window x:Class="MuseumSystem.Pages.AddEditVisitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Добавление/Редактирование посетителя" 
        Height="600" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="20" x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="TitleText" Grid.Row="0" Text="Добавление нового посетителя" 
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#333"/>

        <!-- Тип посетителя -->
        <TextBlock Grid.Row="1" Text="Тип посетителя" FontWeight="SemiBold" Margin="0,5"/>
        <ComboBox x:Name="cmbVisitorType" Grid.Row="2" Height="35" Margin="0,0,0,10" 
                  SelectionChanged="cmbVisitorType_SelectionChanged">
            <ComboBoxItem Content="Физическое лицо" IsSelected="True"/>
            <ComboBoxItem Content="Группа"/>
        </ComboBox>

        <!-- Физическое лицо - Фамилия -->
        <TextBlock x:Name="lblLastName" Grid.Row="3" Text="Фамилия" FontWeight="SemiBold" Margin="0,5"/>
        <TextBox x:Name="txtLastName" Grid.Row="4" Height="35" Margin="0,0,0,10" Padding="5"/>

        <!-- Физическое лицо - Имя -->
        <TextBlock x:Name="lblFirstName" Grid.Row="5" Text="Имя" FontWeight="SemiBold" Margin="0,5"/>
        <TextBox x:Name="txtFirstName" Grid.Row="6" Height="35" Margin="0,0,0,10" Padding="5"/>

        <!-- Группа - Название группы (изначально скрыто) -->
        <TextBlock x:Name="lblGroupName" Grid.Row="3" Text="Название группы" FontWeight="SemiBold" Margin="0,5" Visibility="Collapsed"/>
        <TextBox x:Name="txtGroupName" Grid.Row="4" Height="35" Margin="0,0,0,10" Padding="5" Visibility="Collapsed"/>

        <!-- Группа - Курс (изначально скрыт) -->
        <TextBlock x:Name="lblCourseNumber" Grid.Row="5" Text="Курс" FontWeight="SemiBold" Margin="0,5" Visibility="Collapsed"/>
        <TextBox x:Name="txtCourseNumber" Grid.Row="6" Height="35" Margin="0,0,0,10" Padding="5" Visibility="Collapsed" 
                 PreviewTextInput="NumberValidationTextBox"/>

        <!-- Льготная категория -->
        <TextBlock x:Name="lblVisitorType" Grid.Row="7" Text="Льготная категория" FontWeight="SemiBold" Margin="0,5"/>
        <ComboBox x:Name="cmbVisitorTypeCategory" Grid.Row="8" Height="35" Margin="0,0,0,10" 
                  DisplayMemberPath="TypeName" SelectedValuePath="TypeID"/>

        <!-- Телефон -->
        <TextBlock x:Name="lblPhone" Grid.Row="9" Text="Телефон" FontWeight="SemiBold" Margin="0,5"/>
        <TextBox x:Name="txtPhone" Grid.Row="10" Height="35" Margin="0,0,0,10" Padding="5"/>

        <!-- Email -->
        <TextBlock x:Name="lblEmail" Grid.Row="11" Text="Email" FontWeight="SemiBold" Margin="0,5"/>
        <TextBox x:Name="txtEmail" Grid.Row="12" Height="35" Margin="0,0,0,10" Padding="5"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="13" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="35" Background="#4CAF50" 
                    Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="35" Background="#f44336" 
                    Foreground="White" BorderThickness="0" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>