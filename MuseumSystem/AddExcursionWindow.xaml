<Window x:Class="MuseumSystem.AddExcursionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MuseumSystem"
        mc:Ignorable="d"
        Title="Добавление экскурсий" Height="450" Width="800">
    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добавление новой экскурсии"  FontSize="20" FontWeight="Bold" 
                   Foreground="#333" Margin="0,0,0,20" Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <TextBlock Text="Название экскурсии*" FontWeight="SemiBold" Margin="0,5"/>
                <TextBox x:Name="txtName" Height="30" Padding="5" BorderBrush="#ddd" 
                         BorderThickness="1" MaxLength="200"/>


                <TextBlock Text="Описание"  FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox x:Name="txtDescription"  Height="80" Padding="5" BorderBrush="#ddd" BorderThickness="1"
                         TextWrapping="Wrap" AcceptsReturn="True" MaxLength="500"/>

                <TextBlock Text="Дата и время проведения*" FontWeight="SemiBold" Margin="0,15,0,5"/>
                
                <DatePicker x:Name="dpDate" Height="30" BorderBrush="#ddd" BorderThickness="1"
                           SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Время начала" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBox x:Name="txtStartTime" Height="30" Padding="5"  BorderBrush="#ddd" 
                         BorderThickness="1" Text="10:00"/>

                <TextBlock Text="Время окончания" FontWeight="SemiBold" Margin="0,10,0,5"/>
                <TextBox x:Name="txtEndTime" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1"
                         Text="11:30"/>

                <TextBlock Text="Гид*" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <ComboBox x:Name="cmbGuide" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1" DisplayMemberPath="FullName"
                          SelectedValuePath="EmployeeID"/>

                <TextBlock Text="Максимальное количество посетителей*" FontWeight="SemiBold" Margin="0,15,0,5"/>
                
                <TextBox x:Name="txtMaxVisitors" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1" Text="20"
                         MaxLength="3"/>

                <TextBlock Text="Стоимость (₽)*" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <TextBox x:Name="txtPrice" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1" Text="500"
                         MaxLength="6"/>

                <CheckBox x:Name="chkStatus" Content="Активна" IsChecked="True" Margin="0,15,0,5"
                          FontWeight="SemiBold"/>

                <TextBlock Text="Экспонаты для экскурсии" FontWeight="SemiBold" Margin="0,15,0,5"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="txtSearchExponat" Width="200" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1"
                             TextChanged="txtSearchExponat_TextChanged"/>
                    <TextBlock Text="Поиск экспонатов" Margin="10,5,0,0" Foreground="#888"/>
                </StackPanel>

                <ListBox x:Name="lstExponats"  Height="150" BorderBrush="#ddd" BorderThickness="1" SelectionMode="Multiple"
                         DisplayMemberPath="Name"/>

                <TextBlock x:Name="txtSelectedCount" Text="Выбрано экспонатов: 0" Margin="0,5,0,0" Foreground="#2196F3"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">

            <Button x:Name="BtnSaveExcursion" Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0" Click="BtnSaveExcursion_Click"
                    Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Отмена"  Width="100" Height="35" Click="BtnCancel_Click" Background="#f44336" Foreground="White" 
                    BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>