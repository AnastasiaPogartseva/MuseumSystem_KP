<Window x:Class="MuseumSystem.AddExponatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MuseumSystem"
        mc:Ignorable="d"
        Title="Добавление экспоната" 
        Height="550" Width="500"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">

    <Grid Background="White" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добавление нового экспоната"  FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20" Grid.Row="0"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                
                <TextBlock Text="Инвентарный номер*" FontWeight="SemiBold" Margin="0,5"/>
                
                <TextBox x:Name="txtInventoryNumber" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1" MaxLength="50"/>

                <TextBlock Text="Название экспоната*" FontWeight="SemiBold" Margin="0,15,0,5"/>
                
                <TextBox x:Name="txtName"  Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1" MaxLength="100"/>

                <TextBlock Text="Категория*" FontWeight="SemiBold" Margin="0,15,0,5"/>
                
                <ComboBox x:Name="cmbCategory" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryID"/>

                <TextBlock Text="Год создания*" FontWeight="SemiBold" Margin="0,15,0,5"/>
                
                <TextBox x:Name="txtYearCreated" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1" MaxLength="4"/>

          
                <TextBlock Text="Состояние" FontWeight="SemiBold" Margin="0,15,0,5"/>
                <ComboBox x:Name="cmbCondition" Height="30" Padding="5" BorderBrush="#ddd" BorderThickness="1">
                    <ComboBoxItem Content="Отличное"/>
                    <ComboBoxItem Content="Хорошее" IsSelected="True"/>
                    <ComboBoxItem Content="Удовлетворительное"/>
                    <ComboBoxItem Content="Требует реставрации"/>
                    <ComboBoxItem Content="Аварийное"/>
                </ComboBox>

                <CheckBox x:Name="chkStatus" Content="Доступен для показа" IsChecked="True" Margin="0,15,0,5" FontWeight="SemiBold"/>

                <TextBlock Text="Описание" FontWeight="SemiBold" Margin="0,15,0,5"/>
                
                <TextBox x:Name="txtDescription" Height="80" Padding="5" BorderBrush="#ddd" BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True" MaxLength="500"/>

                <TextBlock Text="История экспоната" FontWeight="SemiBold" Margin="0,15,0,5"/>
                
                <TextBox x:Name="txtHistory" Height="80" Padding="5" BorderBrush="#ddd" BorderThickness="1" TextWrapping="Wrap" AcceptsReturn="True" MaxLength="1000"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">

            <Button x:Name="BtnSaveExponat" Content="Сохранить" Width="100"  Height="35" Margin="0,0,10,0" Click="BtnSaveExponat_Click" Background="#4CAF50" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Отмена" Width="100" Height="35" Click="BtnCancel_Click" Background="#f44336" Foreground="White" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
