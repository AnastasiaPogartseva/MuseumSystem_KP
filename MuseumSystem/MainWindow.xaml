<Window x:Class="MuseumSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MuseumSystem"
        mc:Ignorable="d"
        Title="Музей техникума" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" Icon="/Resources/logo.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

      
        <Grid Background="#2b96d1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Музей техникума" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="24"
                       FontWeight="Bold" Foreground="White" Margin="10,0,0,0"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">

                <Button Content="Выход" Name="BtnExit" Width="80" Background="#ff4444" Foreground="White"
                        Click="BtnExit_Click"/>
            </StackPanel>
            <Image Source="/Resources/logo.png" Width="60" Height="60" Margin="10" Grid.Column="0"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#f5f5f5" BorderBrush="#ddd" BorderThickness="0,0,1,0">
                
                <StackPanel Margin="10">
                    <TextBlock Text="Меню" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Button x:Name="BtnDashboard" Content="Главная" Style="{StaticResource PrimaryButton}" Click="BtnDashboard_Click"/>
                    <Button x:Name="BtnExponats" Content="Экспонаты" Style="{StaticResource PrimaryButton}" Click="BtnExponats_Click"/>
                    <Button x:Name="BtnExcursions" Content="Экскурсии" Style="{StaticResource PrimaryButton}" Click="BtnExcursions_Click"/>
                    <Button x:Name="BtnVisitors" Content="Посетители" Style="{StaticResource PrimaryButton}" Click="BtnVisitors_Click"/>

                    <Separator Margin="0,20,0,10"/>

                    <TextBlock Text="Быстрые действия" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>

                    <Button x:Name="BtnAddExponat" Content="Добавить экспонат" Style="{StaticResource SecondaryButton}" 
                            Click="BtnAddExponat_Click"/>

                    <Button x:Name="BtnAddExcursion" Content="Создать экскурсию" Style="{StaticResource SecondaryButton}"
                            Click="BtnAddExcursion_Click"/>
                </StackPanel>
            </Border>

            <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden"/>
        </Grid>

        <Grid Grid.Row="2" Background="#2b96d1">
            <TextBlock Text="© 2026 Музей техникума. Все права защищены." Foreground="White" HorizontalAlignment="Center"
                       VerticalAlignment="Center" FontSize="12"/>
        </Grid>
    </Grid>
</Window>
