<Page x:Class="MuseumSystem.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="DashboardPage"
      Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30">
            <TextBlock Text="Добро пожаловать в систему управления музеем!" FontSize="32" FontWeight="Bold" Foreground="#8B4513"  HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,20,0,30"/>

            <Grid Margin="0,0,0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#8B4513" BorderThickness="3" CornerRadius="10" Background="#FDF5E6">
                    <StackPanel>
                        <Image Source="/Resources/mus1.jpg" Height="200" Stretch="UniformToFill" Margin="5"/>
                        <TextBlock Text="Экспозиция 'Студенческие годы'" TextAlignment="Center" Foreground="#5D3A1A" FontWeight="SemiBold" Margin="5"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" 
                        BorderBrush="#8B4513" BorderThickness="3" CornerRadius="10" Background="#FDF5E6">
                    <StackPanel>
                        <Image Source="/Resources/mus2.jpg" Height="200" Stretch="UniformToFill" Margin="5"/>
                        <TextBlock Text="Награды и достижения" TextAlignment="Center" Foreground="#5D3A1A" FontWeight="SemiBold" Margin="5"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" BorderBrush="#8B4513" BorderThickness="3" CornerRadius="10" Background="#FDF5E6">
                    <StackPanel>
                        <Image Source="/Resources/mus3.jpg" Height="200" Stretch="UniformToFill" Margin="5"/>
                        <TextBlock Text="Великая Победа" TextAlignment="Center" Foreground="#5D3A1A" FontWeight="SemiBold" Margin="5"/>
                    </StackPanel>
                </Border>
            </Grid>
            
            <Border Background="#FDF5E6" CornerRadius="15" Padding="40" BorderBrush="#8B4513" BorderThickness="2" Margin="0,0,0,30">
                <StackPanel>

                    <TextBlock Text="Наш музей" FontSize="28" FontWeight="Bold" Foreground="#8B4513" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <TextBlock Text="В нашем музее хранятся зачётки," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Тетради, учебники, линейки и счёты," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Предметы, которые мы сотворили," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Спаяли, сварили, руками пошили." FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3,0,15"/>

                    <TextBlock Text="Здесь наши награды, призы и дипломы," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Портреты людей, что нам близко знакомы:" FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Учитель, наставник, друзья и подруги;" FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Здесь память о буднях и праздниках шумных." FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3,0,15"/>

                    <TextBlock Text="Предметы, которые мы подарили," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="С собой привезли, или же смастерили," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Останутся в память другим поколеньям," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Хотя не являются супертвореньем." FontSize="18"  Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3,0,15"/>

                    <TextBlock Text="И пусть пролетают хоть тысячи лет," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Но каждый снимок и каждый портрет," FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Любую вещицу ты снова найдешь" FontSize="18" Foreground="#5D3A1A" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,3"/>

                    <TextBlock Text="Лишь только в музей наш тихо войдешь." FontSize="18" FontWeight="Bold"  Foreground="#8B4513" HorizontalAlignment="Center" FontFamily="Georgia" Margin="0,15,0,10"/>

                    <TextBlock Text="© Коллектив музея" FontSize="16" Foreground="#A0522D" HorizontalAlignment="Right" FontStyle="Italic" Margin="0,20,10,10"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Музей истории учебного заведения • 2025" FontSize="14" Foreground="#888" HorizontalAlignment="Center" Margin="0,20,0,10"/>
        </StackPanel>
    </ScrollViewer>
</Page>