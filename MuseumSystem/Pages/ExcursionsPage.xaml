<Page x:Class="MuseumSystem.Pages.ExcursionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MuseumSystem.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Экскурсии"
      Loaded="ExcursionsPage_Loaded"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ЭКСКУРСИИ" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="20" Foreground="#333"/>

        <Border Grid.Row="1" Background="#f5f5f5" Padding="10" BorderBrush="#ddd" BorderThickness="0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBox x:Name="txtSearch" Width="250" Height="35" Margin="5" VerticalContentAlignment="Center" KeyDown="txtSearch_KeyDown"/>

                    <Button x:Name="BtnSearch" Content="Поиск" Background="#2196F3" Foreground="White" Width="80" Height="35" Margin="5" BorderThickness="0" Click="BtnSearch_Click"/>

                    <ComboBox x:Name="cmbStatusFilter" Width="150" Height="35" Margin="5" SelectionChanged="cmbStatusFilter_SelectionChanged">
                        <ComboBoxItem Content="Все экскурсии" IsSelected="True"/>
                        <ComboBoxItem Content="Активные"/>
                        <ComboBoxItem Content="Завершенные"/>
                    </ComboBox>

                    <Button x:Name="BtnReset" Content="Сбросить" Background="#FF9800" Foreground="White" Width="80" Height="35" Margin="5" BorderThickness="0" Click="BtnReset_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnAdd" Content="Добавить" Background="#4CAF50" Foreground="White" Width="100" Height="35" Margin="5" BorderThickness="0" Click="BtnAdd_Click"/>

                    <Button x:Name="BtnEdit" Content="Редактировать" Background="#2196F3" Foreground="White" Width="120" Height="35" Margin="5" BorderThickness="0" Click="BtnEdit_Click"/>

                    <Button x:Name="BtnDelete" Content="Удалить" Background="#f44336" Foreground="White" Width="100" Height="35" Margin="5" BorderThickness="0" Click="BtnDelete_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="dgExcursions" Grid.Row="2" Margin="10" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="dgExcursions_MouseDoubleClick" Background="White" 
                  BorderBrush="#ddd" BorderThickness="1" RowHeight="35" AlternatingRowBackground="#f9f9f9">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#f5f5f5"/>
                    <Setter Property="BorderBrush" Value="#ddd"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ExcursionID}" Width="50" Visibility="Collapsed"/>

                <DataGridTextColumn Header="Название" Binding="{Binding ExhibitionName}" Width="200"/>

                <DataGridTextColumn Header="Дата" Binding="{Binding DisplayDate, StringFormat={}{0:dd.MM.yyyy}}" Width="100"/>

                <DataGridTextColumn Header="Начало" Binding="{Binding StartTimeDisplay}" Width="80"/>

                <DataGridTextColumn Header="Окончание" Binding="{Binding EndTimeDisplay}" Width="80"/>

                <DataGridTextColumn Header="Гид" Binding="{Binding GuideName}" Width="180"/>

                <DataGridTextColumn Header="Всего мест" Binding="{Binding MaxVisitorsDisplay}" Width="80"/>

                <DataGridTextColumn Header="Занято" Binding="{Binding CurrentVisitorsDisplay}" Width="80"/>

                <DataGridTextColumn Header="Место сбора" Binding="{Binding MeetingPointDisplay}" Width="150"/>

                <DataGridTemplateColumn Header="Статус" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusColor}" CornerRadius="3" Padding="5,2" Margin="2">
                                <TextBlock Text="{Binding StatusText}" Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Просмотреть" Click="MenuItemView_Click"/>
                    <MenuItem Header="Редактировать" Click="MenuItemEdit_Click"/>
                    <Separator/>
                    <MenuItem Header="Список участников" Click="MenuItemParticipants_Click"/>
                    <Separator/>
                    <MenuItem Header="Отметить проведенной" Click="MenuItemComplete_Click"/>
                    <MenuItem Header="Отменить" Click="MenuItemCancel_Click"/>
                    <Separator/>
                    <MenuItem Header="Удалить" Click="MenuItemDelete_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <Border Grid.Row="2" Background="#f5f5f5" Padding="10" BorderBrush="#ddd" BorderThickness="0,1,0,0" VerticalAlignment="Bottom" Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Всего экскурсий:" FontWeight="SemiBold" Margin="10,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" x:Name="TotalExcursionsText" Text="0" FontWeight="Bold" Foreground="#2196F3" FontSize="16" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" Text="Активных:" FontWeight="SemiBold" Margin="10,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3" x:Name="ActiveExcursionsText" Text="0" FontWeight="Bold" Foreground="#4CAF50" FontSize="16" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="4" Text="Всего посетителей:" FontWeight="SemiBold" Margin="10,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="5" x:Name="TotalVisitorsText" Text="0" FontWeight="Bold" Foreground="#FF9800" FontSize="16" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Загрузка данных..." FontSize="24" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="20" Width="300" Margin="0,20"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>