<Page x:Class="MuseumSystem.Pages.ExponatsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MuseumSystem.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Экспонаты"
      Loaded="Page_Loaded">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#f5f5f5" Padding="10" BorderBrush="#ddd" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBox x:Name="txtSearch" Width="300" Height="30" Margin="5" VerticalContentAlignment="Center" KeyDown="txtSearch_KeyDown"/>

                    <Button x:Name="BtnSearch" Content="Поиск" Background="#2196F3" Foreground="White" Width="80" Height="30" Margin="5" BorderThickness="0" Click="BtnSearch_Click"/>

                    <ComboBox x:Name="cmbCategoryFilter" Width="150" Height="30" Margin="5" DisplayMemberPath="CategoryName" SelectedValuePath="CategoryID"/>

                    <ComboBox x:Name="cmbStatusFilter" Width="120" Height="30" Margin="5">
                        <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                        <ComboBoxItem Content="Доступен"/>
                        <ComboBoxItem Content="Не доступен"/>
                    </ComboBox>

                    <ComboBox x:Name="cmbConditionFilter" Width="150" Height="30" Margin="5"/>

                    <Button x:Name="BtnReset" Content="Сбросить" Background="#FF9800" Foreground="White" Width="80" Height="30" Margin="5" BorderThickness="0" Click="BtnReset_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="dgExponats" Grid.Row="1" AutoGenerateColumns="True" AutoGeneratingColumn="dgExponats_AutoGeneratingColumn" MouseDoubleClick="dgExponats_MouseDoubleClick" Margin="10" IsReadOnly="True">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Просмотреть" Click="MenuItemView_Click"/>
                    <MenuItem Header="Редактировать" Click="MenuItemEdit_Click"/>
                    <MenuItem Header="Удалить" Click="MenuItemDelete_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>
    </Grid>
</Page>