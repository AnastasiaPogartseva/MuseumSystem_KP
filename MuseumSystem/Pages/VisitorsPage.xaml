<Page x:Class="MuseumSystem.Pages.VisitorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MuseumSystem.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="800"
      Title="Посетители"
      Loaded="VisitorsPage_Loaded"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ПОСЕТИТЕЛИ МУЗЕЯ" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="20" Foreground="#333"/>

        <Border Grid.Row="1" Background="#f5f5f5" Padding="10" BorderBrush="#ddd" BorderThickness="0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBox x:Name="txtSearch" Width="250" Height="35" Margin="5" VerticalContentAlignment="Center" KeyDown="txtSearch_KeyDown"/>

                    <Button x:Name="BtnSearch" Content="Поиск" Background="#2196F3" Foreground="White" Width="80" Height="35" Margin="5" BorderThickness="0" Click="BtnSearch_Click"/>

                    <ComboBox x:Name="cmbTypeFilter" Width="150" Height="35" Margin="5" SelectionChanged="cmbTypeFilter_SelectionChanged">
                        <ComboBoxItem Content="Все посетители" IsSelected="True"/>
                        <ComboBoxItem Content="Физические лица"/>
                        <ComboBoxItem Content="Группы"/>
                        <ComboBoxItem Content="Льготные категории"/>
                    </ComboBox>

                    <Button x:Name="BtnReset" Content="Сбросить" Background="#FF9800" Foreground="White" Width="80" Height="35" Margin="5" BorderThickness="0" Click="BtnReset_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnAdd" Content="Добавить" Background="#4CAF50" Foreground="White" Width="100" Height="35" Margin="5" BorderThickness="0" Click="BtnAdd_Click"/>

                    <Button x:Name="BtnEdit" Content="Редактировать" Background="#2196F3" Foreground="White" Width="120" Height="35" Margin="5" BorderThickness="0" Click="BtnEdit_Click"/>

                    <Button x:Name="BtnDelete" Content="Удалить" Background="#f44336" Foreground="White" Width="100" Height="35" Margin="5" BorderThickness="0" Click="BtnDelete_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="dgVisitors" Grid.Row="2" Margin="10" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" MouseDoubleClick="dgVisitors_MouseDoubleClick" Background="White" BorderBrush="#ddd" BorderThickness="1" RowHeight="35"
                  AlternatingRowBackground="#f9f9f9">

            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#f5f5f5"/>
                    <Setter Property="BorderBrush" Value="#ddd"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding VisitorID}" Width="50" Visibility="Collapsed"/>

                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="200"/>

                <DataGridTextColumn Header="Тип" Binding="{Binding VisitorType}" Width="120"/>

                <DataGridTextColumn Header="Группа/Курс" Binding="{Binding GroupInfo}" Width="150"/>

                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>

                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>

                <DataGridTextColumn Header="Дата регистрации" Binding="{Binding RegistrationDate, StringFormat={}{0:dd.MM.yyyy}}" 
                                    Width="130"/>

                <DataGridTemplateColumn Header="Статус" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="{Binding StatusColor}" CornerRadius="3" Padding="5,2" Margin="2">
                                <TextBlock Text="{Binding StatusText}" Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Посещений" Binding="{Binding VisitsCount}" Width="80"/>
            </DataGrid.Columns>

            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Просмотреть" x:Name="MenuItemView" Click="MenuItemView_Click"/>
                    <MenuItem Header="Редактировать" x:Name="MenuItemEdit" Click="MenuItemEdit_Click"/>
                    <Separator/>
                    <MenuItem Header="История посещений" x:Name="MenuItemHistory" Click="MenuItemHistory_Click"/>
                    <Separator/>
                    <MenuItem Header="Удалить" x:Name="MenuItemDelete" Click="MenuItemDelete_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <Border Grid.Row="2" Background="#f5f5f5" Padding="10" BorderBrush="#ddd" BorderThickness="0,1,0,0" VerticalAlignment="Bottom" Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Всего посетителей:" FontWeight="SemiBold" Margin="10,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1" x:Name="TotalVisitorsText" Text="0" FontWeight="Bold" Foreground="#2196F3" FontSize="16" Margin="0,0,20,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" Text="Посещают сегодня:" FontWeight="SemiBold" Margin="10,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="3" x:Name="ActiveTodayText" Text="0" FontWeight="Bold" Foreground="#4CAF50" FontSize="16" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#80FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Загрузка данных..." FontSize="24" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True" Height="20" Width="300" Margin="0,20"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>